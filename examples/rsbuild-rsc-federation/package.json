{
  "name": "examples-rsbuild-rsc-federation",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev:e2e": "rsbuild dev --port 3330",
    "verify:manifest": "node ./scripts/verify-manifest.mjs",
    "verify:runtime-plugin": "node --experimental-vm-modules ./scripts/verify-runtime-plugin.mjs",
    "build:verify": "pnpm run build && pnpm run verify:manifest && pnpm run verify:runtime-plugin",
    "test:e2e": "playwright test --config ./playwright.config.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-server-dom-rspack": "0.0.1-beta.1",
    "rsbuild-rsc-federation-shared": "workspace:*"
  },
  "devDependencies": {
    "@module-federation/node": "^2.7.32",
    "@module-federation/runtime-tools": "2.1.0",
    "@playwright/test": "1.58.2",
    "@rsbuild/core": "2.0.0-beta.7",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rspack/core": "workspace:*",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rsbuild-plugin-rsc": "0.0.1-beta.0",
    "typescript": "^5.9.3"
  }
}
